    "web:deploy": "pnpm --filter @taproom/web deploy"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "turbo": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}

